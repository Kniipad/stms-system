# ============================================================
# .env.example
# คัดลอกไฟล์นี้เป็น .env.local แล้วแก้ค่าให้ตรง
# ============================================================

# ── MySQL (Prisma) ───────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://stms_user:stms_password@localhost:3306/stms_db"

# ── MongoDB (Mongoose) ───────────────────────────────────────
# Format: mongodb://USER:PASSWORD@HOST:PORT/DATABASE?authSource=admin
MONGODB_URI="mongodb://stms_admin:stms_mongo_password@localhost:27017/stms_logs?authSource=admin"

# ── JWT ──────────────────────────────────────────────────────
# ใช้คำสั่ง: openssl rand -base64 32 เพื่อสร้าง Secret แบบ Random
JWT_SECRET="stms-super-secret-please-change-in-production"

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
